<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:Quizzamination.Avalonia.ViewModels"
             xmlns:m="clr-namespace:Quizzamination.Models;assembly=Quizzamination.Core"
             x:Class="Quizzamination.Avalonia.Views.LoadView"
             x:DataType="vm:LoadViewModel">

    <Grid Margin="16" RowDefinitions="Auto,*,Auto">

        <!-- Верхній блок -->
        <StackPanel Grid.Row="0" Spacing="10">
            <TextBlock Text="{Binding Status}" TextWrapping="Wrap"/>

            <StackPanel Orientation="Horizontal" Spacing="8">
                <TextBox Width="620"
                         Watermark="Файл тесту (.json або .txt)"
                         Text="{Binding SelectedFilePath}" />

                <Button Content="Огляд…" Click="Browse_Click"/>
                <Button Content="Завантажити" Command="{Binding LoadTestCommand}"/>
                <Button Content="Почати" Command="{Binding StartCommand}"/>
            </StackPanel>

            <TextBlock Text="{Binding Questions.Count, StringFormat=Питань: {0}}"/>
            <Separator/>
        </StackPanel>

        <!-- Список питань -->
        <ListBox Grid.Row="1"
                 Margin="0,8,0,8"
                 ItemsSource="{Binding Questions}">
            <ListBox.ItemTemplate>
                <DataTemplate x:DataType="m:Question">
                    <StackPanel Spacing="4">
                        <TextBlock Text="{Binding Type}" Opacity="0.7"/>
                        <TextBlock Text="{Binding Text}" TextWrapping="Wrap"/>
                    </StackPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <!-- Низ: налаштування старту -->
        <StackPanel Grid.Row="2" Spacing="6" Margin="0,4,0,0">
            <CheckBox Content="Перемішати питання перед стартом"
                      IsChecked="{Binding ShuffleQuestions}"/>
            <CheckBox Content="Режим навчання (показ підказки)"
                      IsChecked="{Binding LearningModeEnabled}"/>
        </StackPanel>

    </Grid>
</UserControl>

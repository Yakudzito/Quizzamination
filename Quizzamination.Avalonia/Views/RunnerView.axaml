<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:Quizzamination.Avalonia.ViewModels"
             x:Class="Quizzamination.Avalonia.Views.RunnerView"
             x:DataType="vm:RunnerViewModel">

    <DockPanel Margin="16" LastChildFill="True">
        <StackPanel DockPanel.Dock="Top" Spacing="8">
            <TextBlock Text="{Binding Status}" Opacity="0.7"/>
            <Separator/>
        </StackPanel>

        <ContentControl Content="{Binding Current}" Margin="0,0,0,12"/>

        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Spacing="8">
            <Button Content="← Назад" Command="{Binding PrevCommand}" IsEnabled="{Binding CanPrev}"/>
            <Button Content="Далі →" Command="{Binding NextCommand}" IsEnabled="{Binding CanNext}"/>
            <Button Content="Завершити" Command="{Binding FinishCommand}"/>
        </StackPanel>
    </DockPanel>
</UserControl>
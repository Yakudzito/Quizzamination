<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:Quizzamination.Avalonia.ViewModels"
             x:Class="Quizzamination.Avalonia.Views.RunnerView"
             x:DataType="vm:RunnerViewModel">

    <Grid Margin="16" RowDefinitions="Auto,*,Auto">

        <!-- Header -->
        <StackPanel Grid.Row="0" Spacing="8">
            <TextBlock Text="{Binding Status}" Opacity="0.7"/>
            <Separator/>
        </StackPanel>

        <!-- Content -->
        <Border Grid.Row="1" Padding="0" VerticalAlignment="Stretch">
            <Grid RowDefinitions="*,Auto,Auto">
                <ContentControl Grid.Row="0" Content="{Binding Current}" VerticalAlignment="Stretch"/>

                <Button Grid.Row="1"
                        Margin="0,12,0,0"
                        HorizontalAlignment="Left"
                        Content="Показати правильну відповідь"
                        IsVisible="{Binding LearningModeEnabled}"
                        Command="{Binding ShowAnswerCommand}"/>

                <Border Grid.Row="2"
                        Margin="0,8,0,0"
                        Padding="10"
                        IsVisible="{Binding IsAnswerRevealed}"
                        BorderBrush="{DynamicResource ThemeForegroundBrush}"
                        BorderThickness="1"
                        CornerRadius="6">
                    <TextBlock Text="{Binding RevealedAnswerText}" TextWrapping="Wrap"/>
                </Border>
            </Grid>
        </Border>

        <!-- Footer -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="8">
            <Button Content="← Назад" Command="{Binding PrevCommand}" IsEnabled="{Binding CanPrev}"/>
            <Button Content="Далі →" Command="{Binding NextCommand}" IsEnabled="{Binding CanNext}"/>
            <Button Content="Завершити" Command="{Binding FinishCommand}"/>
        </StackPanel>

    </Grid>
</UserControl>

<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:qvm="clr-namespace:Quizzamination.Avalonia.ViewModels.Questions"
             x:Class="Quizzamination.Avalonia.Views.Questions.UnsupportedQuestionView"
             x:DataType="qvm:UnsupportedQuestionViewModel">

    <StackPanel Spacing="10">
        <TextBlock Text="{Binding Text}" FontSize="18" TextWrapping="Wrap"/>
        <TextBlock Text="Цей тип питання ще не підтримується в Runner (MVP)."
                   Opacity="0.7"/>
        <TextBlock Text="{Binding Question.Type, StringFormat=Тип: {0}}" Opacity="0.7"/>
    </StackPanel>
</UserControl>
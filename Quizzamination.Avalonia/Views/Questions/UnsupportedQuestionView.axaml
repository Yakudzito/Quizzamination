<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:qvm="clr-namespace:Quizzamination.Avalonia.ViewModels.Questions"
             x:Class="Quizzamination.Avalonia.Views.Questions.UnsupportedQuestionView"
             x:DataType="qvm:UnsupportedQuestionViewModel">

    <Grid RowDefinitions="Auto,Auto,*">
        <TextBlock Grid.Row="0"
                   Text="{Binding Text}"
                   FontSize="18"
                   TextWrapping="Wrap"
                   Margin="0,0,0,12"/>

        <TextBlock Grid.Row="1"
                   Text="{Binding Question.Type, StringFormat=Тип: {0}}"
                   Opacity="0.7"
                   Margin="0,0,0,10"/>

        <Border Grid.Row="2" Padding="6" MinHeight="150">
            <TextBlock Text="Цей тип питання ще не підтримується (MVP)."
                       Opacity="0.7"
                       TextWrapping="Wrap"/>
        </Border>
    </Grid>
</UserControl>
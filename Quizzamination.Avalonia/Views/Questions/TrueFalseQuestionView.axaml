<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:qvm="clr-namespace:Quizzamination.Avalonia.ViewModels.Questions"
             x:Class="Quizzamination.Avalonia.Views.Questions.TrueFalseQuestionView"
             x:DataType="qvm:TrueFalseQuestionViewModel"
             xmlns:conv="clr-namespace:Quizzamination.Avalonia.Converters">

    <Grid RowDefinitions="Auto,*">
        <TextBlock Grid.Row="0"
                   Text="{Binding Text}"
                   FontSize="18"
                   TextWrapping="Wrap"
                   Margin="0,0,0,12"/>

        <Border Grid.Row="1" Padding="6" MinHeight="120">
            <StackPanel Spacing="8">
                <RadioButton Content="True"  GroupName="tf"
                             IsChecked="{Binding Selected, Converter={x:Static conv:IntToBoolConverter.Instance}, ConverterParameter=1}"/>
                <RadioButton Content="False" GroupName="tf"
                             IsChecked="{Binding Selected, Converter={x:Static conv:IntToBoolConverter.Instance}, ConverterParameter=0}"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
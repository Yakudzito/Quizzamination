<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:qvm="clr-namespace:Quizzamination.Avalonia.ViewModels.Questions"
             x:Class="Quizzamination.Avalonia.Views.Questions.ShortAnswerQuestionView"
             x:DataType="qvm:ShortAnswerQuestionViewModel">

    <Grid RowDefinitions="Auto,*">
        <TextBlock Grid.Row="0"
                   Text="{Binding Text}"
                   FontSize="18"
                   TextWrapping="Wrap"
                   Margin="0,0,0,12"/>

        <Border Grid.Row="1" Padding="6" MinHeight="120">
            <TextBox Watermark="Введи відповідь"
                     Text="{Binding Answer}"
                     VerticalAlignment="Top"/>
        </Border>
    </Grid>
</UserControl>
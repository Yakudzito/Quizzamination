<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:qvm="clr-namespace:Quizzamination.Avalonia.ViewModels.Questions"
             x:Class="Quizzamination.Avalonia.Views.Questions.SingleChoiceQuestionView"
             x:DataType="qvm:SingleChoiceQuestionViewModel">

    <Grid RowDefinitions="Auto,Auto,*" VerticalAlignment="Stretch">

        <TextBlock Grid.Row="0"
                   Text="{Binding Text}"
                   FontSize="18"
                   TextWrapping="Wrap"
                   Margin="0,0,0,6"/>

        <TextBlock Grid.Row="1"
                   Text="{Binding Options.Count, StringFormat=Options: {0}}"
                   Opacity="0.6"
                   Margin="0,0,0,10"/>

        <Border Grid.Row="2"
                BorderThickness="1"
                Padding="6"
                MinHeight="250"
                VerticalAlignment="Stretch">

            <ListBox ItemsSource="{Binding Options}"
                     SelectedIndex="{Binding SelectedIndex}"
                     VerticalAlignment="Stretch"/>
        </Border>

    </Grid>
</UserControl>
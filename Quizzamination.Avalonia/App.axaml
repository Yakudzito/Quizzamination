<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="clr-namespace:Quizzamination.Avalonia.Views"
             xmlns:vm="clr-namespace:Quizzamination.Avalonia.ViewModels"
             xmlns:qv="clr-namespace:Quizzamination.Avalonia.Views.Questions"
             xmlns:qvm="clr-namespace:Quizzamination.Avalonia.ViewModels.Questions"
             x:Class="Quizzamination.Avalonia.App">

    <Application.Styles>
        <FluentTheme />
    </Application.Styles>

    <Application.DataTemplates>
        <DataTemplate DataType="{x:Type vm:LoadViewModel}">
            <views:LoadView/>
        </DataTemplate>

        <DataTemplate DataType="{x:Type vm:RunnerViewModel}">
            <views:RunnerView/>
        </DataTemplate>

        <DataTemplate DataType="{x:Type vm:ResultsViewModel}">
            <views:ResultsView/>
        </DataTemplate>

        <DataTemplate DataType="{x:Type qvm:SingleChoiceQuestionViewModel}">
            <qv:SingleChoiceQuestionView/>
        </DataTemplate>

        <DataTemplate DataType="{x:Type qvm:ShortAnswerQuestionViewModel}">
            <qv:ShortAnswerQuestionView/>
        </DataTemplate>

        <DataTemplate DataType="{x:Type qvm:UnsupportedQuestionViewModel}">
            <qv:UnsupportedQuestionView/>
        </DataTemplate>
    </Application.DataTemplates>

</Application>